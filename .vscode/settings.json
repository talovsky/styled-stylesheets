{
	"oxc.enable": true,
	"[typescript]": {
		"editor.defaultFormatter": "oxc.oxc-vscode",
		"editor.formatOnSave": true
	},
	"[typescriptreact]": {
		"editor.defaultFormatter": "oxc.oxc-vscode",
		"editor.formatOnSave": true,
		"editor.codeActionsOnSave": {
			"source.fixAll.stylelint": "always"
		}
	},
	"[css]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.stylelint": "always"
		}
	},
	"stylelint.validate": ["css", "scss", "postcss", "typescriptreact", "tsx"]
	// "stylelint.workingDirectories": [{ "directory": "packages/wyrd", "changeProcessCWD": true }]
}
